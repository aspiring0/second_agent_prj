# ==================== API Key 配置 ====================
# 请复制此文件为 .env 并填入你的 API Key

# OpenAI (必需 - 用于GPT模型和Embedding)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://api.openai.com/v1

# DeepSeek (可选 - 国产替代，性价比高)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# 智谱AI (可选 - GLM系列模型)
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=xxxxxxxxxxxxxxxx

# Moonshot (可选 - 月之暗面，长文本能力强)
# 获取地址: https://platform.moonshot.cn/
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxx

# Azure OpenAI (可选)
AZURE_API_KEY=
AZURE_API_BASE=

# ==================== 模型配置 ====================
# 默认对话模型 (可在Web界面动态切换)
# 可选值: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo, 
#         deepseek-chat, glm-4, glm-4-flash, moonshot-v1-8k 等
CHAT_MODEL=gpt-3.5-turbo

# 默认Embedding模型
# 可选值: text-embedding-3-small, text-embedding-3-large, 
#         text-embedding-ada-002, embedding-2 (智谱)
EMBEDDING_MODEL=text-embedding-3-small

# Agent模型 (用于多智能体系统)
AGENT_MODEL=gpt-4o-mini

# ==================== RAG 参数配置 ====================
# 文档切片大小 (字符数)
CHUNK_SIZE=800

# 切片重叠大小 (字符数)
CHUNK_OVERLAP=100

# 检索返回文档数
RETRIEVAL_TOP_K=3

# ==================== 功能开关 ====================
# 是否启用Web界面模型切换
ENABLE_MODEL_SWITCHING=true